# Published image. Pin this to a numbered release for predictable upgrades.
BIBLIOFUSE_IMAGE=ghcr.io/mlt-solutions/bibliofuse-nas:latest

# Host folders. CONFIG_PATH and CACHE_PATH must be writable by PUID:PGID.
# LIBRARY_PATH is mounted read-only.
CONFIG_PATH=./config
CACHE_PATH=./cache
LIBRARY_PATH=/absolute/path/to/your/books

# Optional JSON boundary for additional read-only container mounts. Leave empty when
# using the standard /library mount.
BF_LIBRARY_BROWSE_ROOTS=

# Numeric identity used inside the container.
PUID=1000
PGID=1000

# IANA timezone used by scheduled library refresh.
BF_TIME_ZONE=UTC

# Optional service label and native API PIN.
BF_SERVICE_NAME=BiblioFuse NAS
BF_SERVER_PIN=

# Optional explicit addresses. These do not enable pairing in the current released
# iOS or visionOS apps.
BF_LAN_HOST=
BF_TAILSCALE_HOST=
BF_TRUSTED_PROXIES=
