# Absolute host paths. The library path is made available to the folder picker as
# "Library" but is not attached or indexed until selected in Settings.
CONFIG_PATH=/srv/bibliofuse/config
CACHE_PATH=/srv/bibliofuse/cache
LIBRARY_PATH=/srv/books

# Run as a host user that can write config/cache and read LIBRARY_PATH.
PUID=1000
PGID=1000
BF_TIME_ZONE=UTC
